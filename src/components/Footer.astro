---
/**
 * Footer.astro
 * Site footer: brand column, category links, company links, bottom bar.
 */
import NewsletterSection from './NewsletterSection.astro';
import { SITE }          from '@data/site';
import { CATEGORIES }    from '@data/categories';

const year = new Date().getFullYear();
---

<footer class="bg-slate-900 text-white" role="contentinfo">

  <!-- ── Newsletter strip ───────────────────────────────── -->
  <NewsletterSection variant="footer" />

  <!-- ── Footer grid ────────────────────────────────────── -->
  <div class="container py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/" class="no-underline" aria-label={`${SITE.name} — Home`}>
          <span class="font-serif text-xl font-bold text-white">{SITE.name}</span>
        </a>
        <p class="mt-3 text-sm text-slate-400 leading-relaxed">
          {SITE.tagline}
        </p>
        <p class="mt-2 text-sm text-slate-500 leading-relaxed">
          {SITE.description.slice(0, 100)}…
        </p>

        <!-- Social links — only renders icons with set URLs -->
        {Object.entries(SITE.social).some(([, v]) => v) && (
          <div class="mt-5 flex gap-3" aria-label="Social media links">
            {SITE.social.twitter && (
              <a href={SITE.social.twitter} target="_blank" rel="noopener noreferrer"
                 class="text-slate-400 hover:text-white transition-colors duration-150"
                 aria-label="Twitter / X">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            )}
            {SITE.social.instagram && (
              <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer"
                 class="text-slate-400 hover:text-white transition-colors duration-150"
                 aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
              </a>
            )}
            {SITE.social.pinterest && (
              <a href={SITE.social.pinterest} target="_blank" rel="noopener noreferrer"
                 class="text-slate-400 hover:text-white transition-colors duration-150"
                 aria-label="Pinterest">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="currentColor" aria-hidden="true">
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
                </svg>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Topics column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">
          Topics
        </h3>
        <ul class="space-y-3" role="list">
          {CATEGORIES.map((cat) => (
            <li>
              <a
                href={`/category/${cat.slug}/`}
                class="text-sm text-slate-400 hover:text-white transition-colors duration-150"
              >
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">
          Company
        </h3>
        <ul class="space-y-3" role="list">
          {SITE.footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-400 hover:text-white transition-colors duration-150"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More column -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">
          More
        </h3>
        <ul class="space-y-3" role="list">
          <li>
            <a href="/rss.xml"
               class="text-sm text-slate-400 hover:text-white transition-colors duration-150">
              RSS Feed
            </a>
          </li>
          <li>
            <a href="/sitemap-index.xml"
               class="text-sm text-slate-400 hover:text-white transition-colors duration-150">
              Sitemap
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ─────────────────────────────────────── -->
  <div class="border-t border-slate-800">
    <div class="container py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-500">
        {SITE.copyright}
      </p>
      <p class="text-xs text-slate-600 text-center sm:text-right max-w-md">
        Lucky Living participates in affiliate advertising programs.
        We may earn a commission when you buy through links on this site.
        <a href="/affiliate-disclosure/" class="underline hover:text-slate-400 ml-1">
          Learn more
        </a>.
      </p>
    </div>
  </div>

</footer>
