---
/**
 * Header.astro
 *
 * Premium sticky header with:
 *   - Glass effect + backdrop blur (uses .glass from global.css)
 *   - Scroll-driven shadow that fades in after 16px scroll
 *   - Two-row desktop layout: logo row + nav row (magazine style)
 *   - Mobile drawer using CSS grid-template-rows animation — no scrollHeight JS
 *   - Keyboard accessible (Escape closes, focus-trap not needed for nav)
 *   - Zero external dependencies, minimal inline script
 */
import Navigation from './Navigation.astro';
import { SITE }   from '@data/site';
---

<!-- ─────────────────────────────────────────────────────────────
     Outer wrapper: sticky positioning + scroll-driven shadow
     JS adds .is-scrolled which triggers the box-shadow transition.
───────────────────────────────────────────────────────────────── -->
<header
  id="site-header"
  class="sticky top-0 z-50 w-full"
  role="banner"
>

  <!--
    Inner surface: glass background.
    Border-bottom is always present but only visible when scrolled
    (opacity controlled via .is-scrolled in the <style> block).
  -->
  <div id="header-surface" class="glass border-b border-slate-200/60 transition-shadow duration-300">
    <div class="container">

      <!-- ── Row 1: Logo + Utilities ─────────────────────── -->
      <div class="flex items-center justify-between h-16 lg:h-[60px]">

        <!-- Logo -->
        <a
          href="/"
          class="group flex items-center gap-2.5 no-underline shrink-0"
          aria-label={`${SITE.name} — Home`}
        >
          <!--
            Logo mark: a small geometric diamond in brand-accent.
            Replace the <svg> with an <img> once a real logo exists.
          -->
          <span
            class="flex items-center justify-center w-7 h-7 rounded-lg
                   bg-brand-accent text-white shrink-0
                   transition-transform duration-200 group-hover:scale-110"
            aria-hidden="true"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1L13 7L7 13L1 7L7 1Z" fill="white" fill-opacity="0.9"/>
            </svg>
          </span>

          <!-- Wordmark -->
          <span
            class="font-serif font-bold text-[1.1rem] tracking-tight text-slate-900
                   transition-colors duration-150 group-hover:text-brand-accent"
          >
            {SITE.name}
          </span>
        </a>

        <!-- Desktop: search link (right side of row 1) -->
        <div class="hidden lg:flex items-center gap-1">
          <a
            href="/search/"
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-slate-500
                   rounded-lg transition-all duration-150
                   hover:text-slate-900 hover:bg-slate-100/70"
            aria-label="Search Lucky Living"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.2"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
            <span class="hidden xl:inline">Search</span>
          </a>
        </div>

        <!-- Mobile: search icon + hamburger -->
        <div class="flex lg:hidden items-center gap-0.5">
          <a
            href="/search/"
            class="flex items-center justify-center w-9 h-9 rounded-lg text-slate-500
                   transition-all duration-150 hover:bg-slate-100/70 hover:text-slate-900"
            aria-label="Search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.2"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
          </a>

          <!-- Hamburger / close toggle -->
          <button
            id="nav-toggle"
            type="button"
            class="flex items-center justify-center w-9 h-9 rounded-lg text-slate-500
                   transition-all duration-150 hover:bg-slate-100/70 hover:text-slate-900"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-drawer"
          >
            <!-- Hamburger (shown when closed) -->
            <svg
              id="icon-menu"
              xmlns="http://www.w3.org/2000/svg"
              width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.2"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="3" y1="6"  x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <!-- X (shown when open) -->
            <svg
              id="icon-close"
              xmlns="http://www.w3.org/2000/svg"
              width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2.2"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
              class="hidden"
            >
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>

      </div><!-- /Row 1 -->

      <!-- ── Row 2: Primary nav (desktop only) ───────────── -->
      <div class="hidden lg:block border-t border-slate-100/80 py-1.5">
        <Navigation />
      </div>

      <!-- ── Mobile drawer ───────────────────────────────── -->
      <!--
        Animation technique: CSS grid-template-rows 0fr → 1fr.
        The inner div has min-height: 0, so the grid can crush it to zero.
        JS only toggles the .drawer-open class — no scrollHeight measurement.
      -->
      <div
        id="mobile-drawer"
        class="lg:hidden grid transition-[grid-template-rows] duration-300 ease-out"
        style="grid-template-rows: 0fr;"
        aria-hidden="true"
      >
        <div class="overflow-hidden">
          <div class="border-t border-slate-100 py-3 pb-5 space-y-0.5">

            <!-- Main nav items -->
            {SITE.nav.map((item) => {
              const currentPath = Astro.url.pathname;
              const active = item.href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(item.href);
              return (
                <a
                  href={item.href}
                  class:list={[
                    'flex items-center px-3 py-2.5 rounded-xl text-sm font-medium',
                    'transition-all duration-150 no-underline',
                    active
                      ? 'bg-brand-accent/8 text-brand-accent font-semibold'
                      : 'text-slate-700 hover:bg-slate-100/80 hover:text-slate-900',
                  ]}
                  aria-current={active ? 'page' : undefined}
                >
                  {item.label}
                </a>
              );
            })}

            <!-- Divider -->
            <div class="h-px bg-slate-100 my-2" role="separator" />

            <!-- Secondary links -->
            {SITE.footerLinks.map((link) => (
              <a
                href={link.href}
                class="flex items-center px-3 py-2 rounded-xl text-sm text-slate-500
                       transition-all duration-150 no-underline
                       hover:bg-slate-100/80 hover:text-slate-700"
              >
                {link.label}
              </a>
            ))}

          </div>
        </div>
      </div><!-- /Mobile drawer -->

    </div><!-- /container -->
  </div><!-- /header-surface -->
</header>

<!-- ─────────────────────────────────────────────────────────────
     Inline script — minimal, no framework, no bundle cost.
     Responsibilities:
       1. Add .is-scrolled to #site-header once page scrolls past 16px
       2. Toggle mobile drawer open/closed via grid-template-rows
       3. Close drawer on Escape or outside click
───────────────────────────────────────────────────────────────── -->
<script>
(function () {
  const header  = document.getElementById('site-header');
  const surface = document.getElementById('header-surface');
  const toggle  = document.getElementById('nav-toggle');
  const drawer  = document.getElementById('mobile-drawer');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  if (!header || !surface || !toggle || !drawer) return;

  // ── 1. Scroll-driven shadow ──────────────────────────────
  let ticking = false;

  function updateScrollState() {
    if (window.scrollY > 16) {
      surface.style.boxShadow = '0 4px 24px -4px rgb(0 0 0 / 0.10), 0 1px 4px -1px rgb(0 0 0 / 0.06)';
    } else {
      surface.style.boxShadow = '';
    }
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateScrollState);
      ticking = true;
    }
  }, { passive: true });

  // Run once on load in case the page starts scrolled (e.g. back-navigation)
  updateScrollState();

  // ── 2. Mobile drawer toggle ──────────────────────────────
  let isOpen = false;

  function openDrawer() {
    isOpen = true;
    drawer.style.gridTemplateRows = '1fr';
    drawer.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close menu');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    // Prevent body scroll while drawer is open on mobile
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    isOpen = false;
    drawer.style.gridTemplateRows = '0fr';
    drawer.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    isOpen ? closeDrawer() : openDrawer();
  });

  // ── 3. Close on Escape ───────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeDrawer();
      toggle.focus();
    }
  });

  // ── 4. Close on outside click ────────────────────────────
  document.addEventListener('click', (e) => {
    if (isOpen && !header.contains(e.target as Node)) {
      closeDrawer();
    }
  });

  // ── 5. Close drawer on route change (resize safety) ─────
  // If viewport grows past the lg breakpoint while drawer is open, close it.
  const mq = window.matchMedia('(min-width: 1024px)');
  mq.addEventListener('change', (e) => {
    if (e.matches && isOpen) closeDrawer();
  });
})();
</script>

<style>
  /*
    Scoped styles for header-specific effects that can't be
    cleanly expressed with Tailwind utilities alone.
  */

  /*
    bg-brand-accent/8 doesn't parse in all Tailwind 4 builds —
    define the active mobile item colour here as a fallback.
  */
  .mobile-nav-active {
    background-color: rgb(37 99 235 / 0.08);
    color: #2563EB;
    font-weight: 600;
  }

  /*
    Ensure the header surface sits against the browser chrome
    on iOS Safari with safe-area insets.
  */
  #header-surface {
    padding-top: env(safe-area-inset-top, 0px);
  }
</style>
