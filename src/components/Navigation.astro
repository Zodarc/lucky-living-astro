---
/**
 * Navigation.astro
 *
 * Desktop primary nav. Rendered inside Header.astro's Row 2.
 *
 * Active state treatment:
 *   - Active link: slate-900 text + 2px brand-accent bottom border (magazine tab style)
 *   - Hover: slate-900 text + translucent background fill
 *   - Transition: border grows up from nothing (transform scaleX)
 *
 * This component is desktop-only. The mobile equivalent is
 * inlined directly in Header.astro to share the Astro.url context.
 */
import { SITE } from '@data/site';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav aria-label="Primary navigation">
  <ul class="flex items-center gap-0.5" role="list">

    {SITE.nav.map((item) => {
      const active = isActive(item.href);
      return (
        <li>
          <a
            href={item.href}
            class:list={[
              // Base
              'relative flex items-center px-3 py-2 text-sm font-medium rounded-lg',
              'no-underline select-none whitespace-nowrap',
              'transition-colors duration-150',
              // Active vs default
              active
                ? 'text-slate-900'
                : 'text-slate-500 hover:text-slate-900 hover:bg-slate-100/70',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {item.label}

            <!--
              Active indicator: a 2px line that slides up from under the text.
              Implemented as an ::after pseudo, but since Astro scopes styles
              per-component, we use an explicit <span> so it works without
              the `is:global` flag or needing to mirror every nav item in CSS.
            -->
            <span
              aria-hidden="true"
              class:list={[
                'absolute bottom-0 left-3 right-3 h-0.5 rounded-full',
                'transition-transform duration-200 origin-left',
                active
                  ? 'bg-brand-accent scale-x-100'
                  : 'bg-brand-accent scale-x-0 group-hover:scale-x-100',
              ]}
            />
          </a>
        </li>
      );
    })}

  </ul>
</nav>
