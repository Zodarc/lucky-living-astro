---
/**
 * SEOHead.astro
 * Single source of truth for all <head> SEO tags.
 * Inject into every layout via <SEOHead {...props} />
 */
import { SITE } from '@data/site';
import {
  buildTitle,
  buildCanonical,
  buildOgImageUrl,
  type SeoProps,
} from '@utils/seo';

interface Props extends SeoProps {
  /** Pre-built JSON-LD schema string(s) — pass one or an array */
  schema?: string | string[];
}

const {
  title,
  description,
  keywords     = [],
  canonical,
  ogImage,
  ogType       = 'website',
  noindex      = false,
  publishDate,
  updatedDate,
  author,
  schema,
} = Astro.props;

const pageTitle    = buildTitle(title);
const pageDesc     = description ?? SITE.description;
const pageCanonical= canonical
  ? (canonical.startsWith('http') ? canonical : buildCanonical(canonical))
  : Astro.url.href;
const pageOgImage  = buildOgImageUrl(ogImage);
const pageKeywords = keywords.length
  ? keywords.join(', ')
  : SITE.seo.defaultKeywords;

// Normalise schema to array
const schemas = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : [];
---

<!-- ── Charset & viewport ─────────────────────────────────── -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- ── Primary SEO ───────────────────────────────────────── -->
<title>{pageTitle}</title>
<meta name="description"  content={pageDesc} />
<meta name="keywords"     content={pageKeywords} />
<meta name="robots"       content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="author"       content={author ?? SITE.name} />
<link rel="canonical"     href={pageCanonical} />

<!-- ── Open Graph ────────────────────────────────────────── -->
<meta property="og:type"        content={ogType} />
<meta property="og:site_name"   content={SITE.name} />
<meta property="og:title"       content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:image"       content={pageOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height"content="630" />
<meta property="og:url"         content={pageCanonical} />
<meta property="og:locale"      content={SITE.locale} />
{ogType === 'article' && publishDate && (
  <meta property="article:published_time" content={publishDate.toISOString()} />
)}
{ogType === 'article' && updatedDate && (
  <meta property="article:modified_time"  content={updatedDate.toISOString()} />
)}
{ogType === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<!-- ── Twitter Card ──────────────────────────────────────── -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content={SITE.seo.twitterHandle} />
<meta name="twitter:title"       content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image"       content={pageOgImage} />

<!-- ── Favicons ──────────────────────────────────────────── -->
<link rel="icon"             type="image/x-icon" href="/favicon/favicon.ico" />
<link rel="icon"             type="image/png"    sizes="32x32" href="/favicon/favicon-32x32.png" />
<link rel="icon"             type="image/png"    sizes="16x16" href="/favicon/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180"                   href="/favicon/apple-touch-icon.png" />
<meta name="theme-color"     content="#0F172A" />

<!-- ── RSS Feed ──────────────────────────────────────────── -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.name} RSS Feed`}
  href="/rss.xml"
/>

<!-- ── JSON-LD Schema ────────────────────────────────────── -->
{schemas.map((s) => (
  <script type="application/ld+json" set:html={s} />
))}
