---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  linkText?: string;
  linkHref?: string;
}

const {
  eyebrow,
  title,
  description,
  linkText,
  linkHref
} = Astro.props;
---

<div class="section-header-premium mb-10">

  <div class="flex items-end justify-between gap-6">

    <div>

      {eyebrow && (
        <p class="text-xs uppercase tracking-[0.3em] font-bold text-amber-600 mb-3">
          {eyebrow}
        </p>
      )}

      <h2 class="font-serif text-3xl lg:text-5xl font-bold text-slate-900 leading-tight">
        {title}
      </h2>

      {description && (
        <p class="mt-3 text-slate-500 max-w-xl text-base leading-relaxed">
          {description}
        </p>
      )}

    </div>


    {linkText && linkHref && (
      <a
        href={linkHref}
        class="hidden sm:inline-flex text-sm font-semibold text-slate-600 hover:text-slate-900 transition"
      >
        {linkText} →
      </a>
    )}

  </div>

</div>