---
/**
 * BaseLayout.astro
 * Root layout for every page. Composes SEOHead + Header + Footer.
 */

import SEOHead from '@components/SEOHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

import '@styles/global.css';
import '@scripts/animations';

import type { SeoProps } from '@utils/seo';

interface Props extends SeoProps {
  schema?: string | string[];
}

const seoProps = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <SEOHead {...seoProps} />

  <!--
    No-JS safety net:
    If JavaScript is disabled, reveal all animated elements.
    When animations.ts runs, it enables the animation system.
  -->
  <noscript>
    <style>
      [data-animate] {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>
</head>

<body class="min-h-screen flex flex-col bg-white text-slate-900">

  <!-- Accessibility skip link -->
  <a href="#main-content" class="skip-link">
    Skip to main content
  </a>

  <Header />

  <main id="main-content" class="flex-1" tabindex="-1">
    <slot />
  </main>

  <Footer />

</body>
</html>