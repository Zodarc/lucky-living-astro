<!-- ═══════════════════════════════════════════════════════════
     FEATURED REVIEWS — Premium product showcase
     ─────────────────────────────────────────────────────────
     Layout:
       Desktop : large featured card (left, ~60%) + 3 supporting
                 ProductCards (right, ~40%) in a vertical stack
       Tablet  : 2-col grid
       Mobile  : single column
     Data:
       topProducts[0]      → bespoke featured card (inline markup)
       topProducts.slice(1)→ reuses <ProductCard /> unchanged
     No logic is duplicated from ProductCard.
═══════════════════════════════════════════════════════════════ -->
{topProducts.length > 0 && (
  <section
    class="pr-section relative py-20 lg:py-28 overflow-hidden"
    aria-labelledby="products-heading"
  >

    <!-- Decorative background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
         style="background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);" />
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full pointer-events-none"
         aria-hidden="true"
         style="background: radial-gradient(circle, rgb(217 119 6 / 0.07) 0%, transparent 70%);
                filter: blur(64px);" />
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full pointer-events-none"
         aria-hidden="true"
         style="background: radial-gradient(circle, rgb(37 99 235 / 0.05) 0%, transparent 70%);
                filter: blur(56px);" />

    <div class="container relative z-10">

      <!-- ── Section header ─────────────────────────────── -->
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12 lg:mb-16">
        <div>
          <p class="eyebrow mb-3" style="color: var(--color-brand-gold);">Editor's Picks</p>
          <h2
            id="products-heading"
            class="font-serif font-bold text-slate-900 tracking-tight text-balance mb-4"
            style="font-size: clamp(2rem, 4vw, 3rem);"
          >
            Featured Reviews
          </h2>
          <p class="text-slate-500 max-w-lg leading-relaxed" style="font-size: 1.0625rem;">
            Every review is independently researched and rigorously tested — designed
            to help you make informed buying decisions with complete confidence.
          </p>
        </div>
        <a
          href="/category/reviews/"
          class="pr-view-all flex-shrink-0 inline-flex items-center gap-2 px-6 py-3 rounded-full
                 text-sm font-semibold no-underline border-2 border-slate-200 text-slate-700
                 transition-all duration-200 hover:border-brand-accent hover:text-brand-accent
                 hover:shadow-md self-start sm:self-auto"
        >
          View All Reviews
          <svg class="pr-view-arrow" xmlns="http://www.w3.org/2000/svg" width="15" height="15"
               viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
               aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- ── Main grid: featured (left) + supporting (right) ── -->
      <div class="pr-grid">

        <!-- ════════════════════════════════════════════════
             FEATURED REVIEW — large bespoke card
             Renders topProducts[0] data directly.
             No logic duplicated from ProductCard.
        ════════════════════════════════════════════════ -->
        {topProducts[0] && (() => {
          const fp = topProducts[0];
          const fpCat = getCategoryBySlug(fp.data.category);
          const fpFull  = fp.data.rating ? Math.floor(fp.data.rating) : 0;
          const fpHalf  = fp.data.rating ? fp.data.rating % 1 >= 0.5 : false;
          const fpEmpty = 5 - fpFull - (fpHalf ? 1 : 0);
          const fpScore = !fp.data.rating ? '#64748B'
            : fp.data.rating >= 4.5 ? '#D97706'
            : fp.data.rating >= 4.0 ? '#059669'
            : '#64748B';
          const fpPros = (fp.data.pros ?? []).slice(0, 3);
          const fpCons = (fp.data.cons ?? []).slice(0, 2);
          return (
            <article
              class="pr-featured group"
              data-animate="fade-up"
            >
              <!-- Image zone -->
              <a
                href={`/reviews/${fp.slug}/`}
                class="pr-feat-img-wrap block relative overflow-hidden no-underline"
                aria-label={`View review: ${fp.data.name}`}
                tabindex="-1"
                aria-hidden="true"
              >
                <!-- Category-tinted gradient wash behind product -->
                <div class="absolute inset-0" aria-hidden="true"
                     style={fpCat
                       ? `background: radial-gradient(ellipse at 50% 40%, ${fpCat.accentHex}18 0%, #F1F5F9 70%);`
                       : 'background: radial-gradient(ellipse at 50% 40%, #DBEAFE 0%, #F1F5F9 70%);'} />

                {fp.data.image ? (
                  <img
                    src={fp.data.image}
                    alt={fp.data.imageAlt || fp.data.name}
                    width="600"
                    height="450"
                    class="pr-feat-img relative w-full h-full object-contain p-8
                           transition-[transform,filter] duration-500"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-slate-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1" aria-hidden="true">
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                      <circle cx="9" cy="9" r="2"/>
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                    </svg>
                  </div>
                )}

                <!-- Soft bottom vignette for image area -->
                <div class="absolute inset-x-0 bottom-0 h-1/3 pointer-events-none"
                     aria-hidden="true"
                     style="background: linear-gradient(to top, #F1F5F9 0%, transparent 100%);" />

                <!-- Trust badge — top-left -->
                <div class="absolute top-4 left-4 flex flex-col gap-2">
                  <span class="pr-trust-badge inline-flex items-center gap-1.5 px-2.5 py-1.5
                               rounded-full text-[10px] font-bold uppercase tracking-wider
                               text-amber-700 shadow-sm"
                        style="background: #FEF3C7; border: 1px solid #FDE68A;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"
                         viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    Editor's Choice
                  </span>
                </div>

                <!-- Rating badge — top-right -->
                {fp.data.rating && (
                  <div class="absolute top-4 right-4 flex flex-col items-center justify-center
                               w-14 h-14 rounded-2xl text-white shadow-lg
                               transition-transform duration-200 group-hover:scale-110"
                       style={`background: ${fpScore};`}
                       aria-hidden="true">
                    <span class="text-xl font-bold leading-none tabular-nums">{fp.data.rating}</span>
                    <span class="text-[9px] font-semibold uppercase tracking-wide opacity-80 mt-0.5">/5</span>
                  </div>
                )}

                <!-- Category pill — bottom-left -->
                {fpCat && (
                  <span class="absolute bottom-4 left-4 badge"
                        style={`background: ${fpCat.accentHex}1a; color: ${fpCat.accentHex};`}>
                    {fpCat.name}
                  </span>
                )}
              </a>

              <!-- Content zone -->
              <div class="pr-feat-body">

                <!-- Stars + Expert Score -->
                {fp.data.rating && (
                  <div class="flex items-center gap-2.5 mb-4"
                       role="img"
                       aria-label={`Rated ${fp.data.rating} out of 5 stars`}>
                    <div class="flex gap-0.5">
                      {Array.from({ length: fpFull }).map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                             fill="currentColor" class="w-4 h-4 text-amber-400" aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      ))}
                      {fpHalf && (
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                             fill="currentColor" class="w-4 h-4 text-amber-400 opacity-50"
                             aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      )}
                      {Array.from({ length: fpEmpty }).map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.5"
                             class="w-4 h-4 text-slate-300" aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                      ))}
                    </div>
                    <span class="text-sm font-bold tabular-nums" style={`color: ${fpScore};`}>
                      {fp.data.rating}
                    </span>
                    <span class="text-xs text-slate-400 font-medium">Expert Score</span>
                  </div>
                )}

                <!-- Headline -->
                <a href={`/reviews/${fp.slug}/`} class="no-underline block mb-3">
                  <h3 class="pr-feat-title font-serif font-bold text-slate-900 leading-snug
                             text-balance transition-colors duration-150
                             group-hover:text-brand-accent"
                      style="font-size: clamp(1.3rem, 2.5vw, 1.75rem);">
                    {fp.data.name}
                  </h3>
                </a>

                <!-- Summary -->
                {fp.data.description && (
                  <p class="text-slate-500 leading-relaxed mb-5 line-clamp-3"
                     style="font-size: 0.9375rem;">
                    {fp.data.description}
                  </p>
                )}

                <!-- Pros + Cons mini cards -->
                {(fpPros.length > 0 || fpCons.length > 0) && (
                  <div class="grid grid-cols-2 gap-3 mb-6">
                    {fpPros.length > 0 && (
                      <div class="rounded-xl p-3.5"
                           style="background: #F0FDF4; border: 1px solid #BBF7D0;">
                        <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-700 mb-2.5">
                          Pros
                        </p>
                        <ul class="space-y-1.5">
                          {fpPros.map((pro) => (
                            <li class="flex items-start gap-1.5 text-xs text-emerald-800 leading-snug">
                              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11"
                                   viewBox="0 0 24 24" fill="none" stroke="#059669"
                                   stroke-width="3" class="flex-shrink-0 mt-px" aria-hidden="true">
                                <path d="M20 6 9 17l-5-5"/>
                              </svg>
                              <span class="line-clamp-1">{pro}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                    {fpCons.length > 0 && (
                      <div class="rounded-xl p-3.5"
                           style="background: #FFF1F2; border: 1px solid #FECDD3;">
                        <p class="text-[10px] font-bold uppercase tracking-wider text-rose-700 mb-2.5">
                          Cons
                        </p>
                        <ul class="space-y-1.5">
                          {fpCons.map((con) => (
                            <li class="flex items-start gap-1.5 text-xs text-rose-800 leading-snug">
                              <span class="text-rose-400 flex-shrink-0 font-bold mt-[-1px]">&bull;</span>
                              <span class="line-clamp-1">{con}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </div>
                )}

                <!-- Price + CTA -->
                <div class="pt-5 border-t border-slate-100 space-y-3">
                  {fp.data.pricePlaceholder && (
                    <div class="flex items-baseline justify-between">
                      <div>
                        <p class="text-[10px] uppercase tracking-wider text-slate-400 font-medium mb-0.5">
                          Price
                        </p>
                        <p class="text-2xl font-bold text-slate-900 tabular-nums leading-none">
                          {fp.data.pricePlaceholder}
                        </p>
                      </div>
                      <span class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-full
                                   text-[10px] font-semibold uppercase tracking-wide
                                   text-emerald-700 bg-emerald-50 border border-emerald-200">
                        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="3" aria-hidden="true">
                          <path d="M20 6 9 17l-5-5"/>
                        </svg>
                        Best Price
                      </span>
                    </div>
                  )}

                  <a
                    href={fp.data.affiliateUrl}
                    target="_blank"
                    rel="nofollow sponsored noopener noreferrer"
                    class="pr-cta-btn flex items-center justify-center gap-2.5
                           w-full py-4 rounded-2xl font-semibold text-white no-underline
                           transition-all duration-250"
                    style="background: linear-gradient(135deg, #D97706 0%, #B45309 100%);
                           box-shadow: 0 4px 16px -2px rgb(217 119 6 / 0.4);"
                    aria-label={`${fp.data.affiliateLabel ?? 'Check Price'} for ${fp.data.name} — opens retailer site`}
                  >
                    {fp.data.affiliateLabel ?? 'See Today\'s Price'}
                    <svg class="pr-cta-arrow" xmlns="http://www.w3.org/2000/svg"
                         width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>

                  <p class="text-center text-[10px] text-slate-400">
                    Opens on retailer site &middot; We may earn a commission
                  </p>
                </div>

              </div>
            </article>
          );
        })()}

        <!-- ════════════════════════════════════════════════
             SUPPORTING REVIEWS — reuse ProductCard unchanged
        ════════════════════════════════════════════════ -->
        {topProducts.length > 1 && (
          <div class="pr-supporting">
            {topProducts.slice(1).map((product, i) => (
              <div data-animate="fade-up" data-delay={String(i * 100)}>
                <ProductCard entry={product} />
              </div>
            ))}
          </div>
        )}

      </div><!-- /pr-grid -->

      <!-- ── Trust banner ────────────────────────────────── -->
      <div class="mt-12 pt-8 border-t border-slate-200">
        <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
            role="list">
          {[
            { icon: '✓', label: 'Expert Tested' },
            { icon: '✓', label: 'Independent Reviews' },
            { icon: '✓', label: 'Updated Regularly' },
            { icon: '✓', label: 'Affiliate Supported' },
          ].map((item) => (
            <li class="flex items-center gap-2 text-sm text-slate-500">
              <span class="flex items-center justify-center w-5 h-5 rounded-full
                           text-emerald-600 font-bold text-xs flex-shrink-0"
                    style="background: #D1FAE5;"
                    aria-hidden="true">
                {item.icon}
              </span>
              {item.label}
            </li>
          ))}
        </ul>

        <!-- Affiliate disclosure -->
        <p class="text-xs text-slate-400 text-center mt-4 max-w-lg mx-auto leading-relaxed">
          {SITE.affiliate.disclosureShort}{' '}
          <a href={SITE.affiliate.disclosureUrl}
             class="underline underline-offset-2 hover:text-slate-600 transition-colors">
            Learn more
          </a>.
        </p>
      </div>

    </div>
  </section>
)}

<!-- EDITOR'S PICKS -->
{featuredArticles.length > 0 && (
  <section class="section bg-white" aria-labelledby="editors-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow mb-1.5">Handpicked</p>
          <h2 id="editors-heading" class="section-title">Editor's Picks</h2>
        </div>
        <a href="/category/reviews/" class="section-link hidden sm:inline">View all &rarr;</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {featuredArticles.map((article) => <ArticleCard entry={article} />)}
      </div>
    </div>
  </section>
)}

<!-- NEWSLETTER -->
<div id="newsletter">
  <NewsletterSection />
</div>

</BaseLayout>

