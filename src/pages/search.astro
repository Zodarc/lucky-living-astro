---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search | Lucky Living"
  description="Search Lucky Living articles and guides."
>

<section class="section">
  <div class="container">

    <h1 class="section-title">
      Search Lucky Living
    </h1>

    <div class="mt-8">
      <input
        type="search"
        placeholder="Search articles..."
        class="input"
      />
    </div>

    <p class="mt-6 text-slate-500">
      Search functionality coming soon.
    </p>

  </div>
</section>

</BaseLayout>