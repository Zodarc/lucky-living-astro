---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search | Lucky Living"
  description="Search Lucky Living articles, guides, and reviews."
>


<section class="section">

<div class="container">

<h1 class="section-title">
Search Lucky Living
</h1>


<input
id="searchBox"
type="search"
placeholder="Search articles and reviews..."
class="input mt-8"
/>


<div id="results" class="mt-8 space-y-4">
</div>


</div>

</section>


<script>

const input = document.querySelector("#searchBox");
const results = document.querySelector("#results");


let items = [];


fetch("/search.json")
.then(res => res.json())
.then(data => {
  items = data;
});


input.addEventListener("input", () => {

const query = input.value.toLowerCase().trim();


if(!query){
  results.innerHTML="";
  return;
}


const matches = items.filter(item => {

const text = [
 item.title,
 item.description,
 item.category,
 ...(item.tags || [])
]
.join(" ")
.toLowerCase();


return text.includes(query);

});


results.innerHTML = matches.length

? matches.map(item => `

<a href="${item.url}"
class="block rounded-xl border border-slate-200 p-5 hover:bg-slate-50">

<h2 class="font-bold text-lg">
${item.title}
</h2>

<p class="text-sm text-slate-500">
${item.type} · ${item.category}
</p>

<p class="mt-2 text-slate-600">
${item.description}
</p>

</a>

`).join("")

:

`<p class="text-slate-500">
No results found.
</p>`;

});

</script>


</BaseLayout>